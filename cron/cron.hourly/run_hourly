#!/bin/sh

LOG_DIR=/data/logs
LOG_FILE=${LOG_DIR}/cron.log
mkdir -p ${LOG_DIR}

START=$(date '+%Y-%m-%d %H:%M:%S')
echo "[${START}] [hourly] basic_data_daily_job START" >> ${LOG_FILE}

cd /data/InStock
uv run --frozen instock-job basic_data_daily_job >> ${LOG_FILE} 2>&1
EXIT_CODE=$?

END=$(date '+%Y-%m-%d %H:%M:%S')
if [ ${EXIT_CODE} -eq 0 ]; then
    echo "[${END}] [hourly] basic_data_daily_job END (success, started at ${START})" >> ${LOG_FILE}
else
    echo "[${END}] [hourly] basic_data_daily_job FAILED (exit_code=${EXIT_CODE}, started at ${START})" >> ${LOG_FILE}
fi
